# Facebook App Configuration
FACEBOOK_APP_ID=your_app_id
FACEBOOK_APP_SECRET=your_app_secret
FACEBOOK_PAGE_ACCESS_TOKEN=your_page_access_token
FACEBOOK_VERIFY_TOKEN=your_custom_verify_token

# LLM Configuration
OPENAI_API_KEY=your_openai_api_key
GROQ_API_KEY=your_groq_api_key

# LLM Provider principal: "openai" (fallback auto vers Groq si erreur)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
GROQ_MODEL=llama-3.3-70b-versatile

# n8n Configuration
N8N_BASE_URL=https://your-n8n-instance.com

# ChromaDB Configuration
CHROMA_PERSIST_DIRECTORY=./data/chroma_db
CHROMA_COLLECTION_NAME=knowledge_base

# Embedding Configuration
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# RAG Configuration
RAG_TOP_K=5
RAG_CONFIDENCE_HIGH=0.75
RAG_CONFIDENCE_MEDIUM=0.50
RAG_CONFIDENCE_LOW=0.30

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Rate Limiting
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_PERIOD=60

# Contact Information (pour escalade)
SUPPORT_EMAIL=support@example.com
SUPPORT_PHONE=+33 1 23 45 67 89
